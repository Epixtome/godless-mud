# Godless Engine Configuration
# Copy this file to .env and adjust as needed.

# --- Network Settings ---
HOST=0.0.0.0
PORT_TELNET=8888
PORT_WS=8889
PORT_API=8000

# --- Logging ---
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# --- Frontend Development ---
# If you are running the React client in Dev mode (npm run dev), 
# it will look for the API on port 8000 by default.
VITE_PORT=3000

# --- Security ---
# Blacklist file path
BLACKLIST_PATH=data/blacklist.txt

# --- AI & External Services (Optional) ---
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
